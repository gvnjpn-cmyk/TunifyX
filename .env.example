# ─────────────────────────────────────────────────────────────
# TunifyX — Environment Variables
# Copy file ini ke .env.local dan isi dengan key kamu
# ─────────────────────────────────────────────────────────────

# YouTube Data API v3
# Dapatkan di: https://console.cloud.google.com
# Enable "YouTube Data API v3" di Library
YOUTUBE_API_KEY=your_youtube_api_key_here

# OpenRouter (untuk AI features) — opsional, gratis tersedia
# Daftar di: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here
